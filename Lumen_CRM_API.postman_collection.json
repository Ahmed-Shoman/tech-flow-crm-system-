              "raw": "{{base_url}}/leads/1",
              "host": ["{{base_url}}"],
              "path": ["leads", "1"]
            }
          }
        },
        {
          "name": "Assign Lead",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"assignee_id\": 3\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/leads/1/assign",
              "host": ["{{base_url}}"],
              "path": ["leads", "1", "assign"]
            }
          }
        },
        {
          "name": "Update Stage",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"stage\": \"won\",\n    \"comment\": \"Client agreed to all terms and signed contract\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/leads/1/stage",
              "host": ["{{base_url}}"],
              "path": ["leads", "1", "stage"]
            }
          }
        },
        {
          "name": "Bulk Assign",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"lead_ids\": [1, 2, 3, 4],\n    \"assignee_id\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/leads/bulk-assign",
              "host": ["{{base_url}}"],
              "path": ["leads", "bulk-assign"]
            }
          }
        }
      ]
